{
  "name": "pi-gui",
  "private": true,
  "version": "0.3.4",
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "pnpm --filter @pi-gui/desktop dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm --filter @pi-gui/session-driver build && pnpm --filter @pi-gui/catalogs build && pnpm --filter @pi-gui/pi-sdk-driver build && pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "electron",
      "electron-winstaller",
      "koffi",
      "sharp",
      "protobufjs"
    ],
    "patchedDependencies": {
      "@mariozechner/pi-ai@0.63.1": "patches/@mariozechner__pi-ai@0.63.1.patch"
    }
  }
}
