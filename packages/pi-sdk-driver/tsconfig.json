{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "composite": false,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {}
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
