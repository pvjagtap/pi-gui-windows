+function updateRecordValue<T>(
+  record: Readonly<Record<string, T>>,
+  key: string,
+  value: T | undefined,
+): Readonly<Record<string, T>> {
+  if (value === undefined) {
+    if (!(key in record)) {
+      return record;
+    }
+
+    const { [key]: _removed, ...rest } = record;
+    return rest;
+  }
+
+  if (record[key] === value) {
+    return record;
+  }
+
+  return {
+    ...record,
+    [key]: value,
+  };
+}
 
